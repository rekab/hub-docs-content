LM_STUDIO_URL=http://host.lan:1234
LM_STUDIO_MODEL=google/gemma-4-31b

# Path to the OAuth client_secret.json downloaded from Cloud Console
# (Desktop app type). Used once on first run of the `download` subcommand;
# the resulting refresh token is persisted at tools/token.json.
GOOGLE_OAUTH_CLIENT_SECRETS=tools/client_secret.json

# Optional: override the input CSV path.
AUDIT_CSV=tools/inputs/william-hub-audit-2026-04-29T05_47_18 - Sheet1.csv
